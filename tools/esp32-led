#!/usr/bin/env python3
"""ESP32 LED 状态控制 — Claude Code 联动
用法: esp32-led idle|busy|waiting
"""
import sys, os

PORT = '/dev/cu.usbmodem1101'
STATUS = sys.argv[1] if len(sys.argv) > 1 else ''

if STATUS not in ('idle', 'busy', 'waiting'):
    print('用法: esp32-led idle|busy|waiting')
    sys.exit(1)

try:
    fd = os.open(PORT, os.O_WRONLY | os.O_NOCTTY)
    os.write(fd, f'STATUS:{STATUS}\n'.encode())
    os.close(fd)
except Exception as e:
    sys.stderr.write(f'esp32-led: {e}\n')
    sys.exit(1)
