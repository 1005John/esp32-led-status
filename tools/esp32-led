#!/usr/bin/env python3
"""ESP32 LED 状态控制 — USB 优先，WiFi 回退
用法: esp32-led idle|busy|waiting
"""
import sys, os, glob, urllib.request, json

STATUS = sys.argv[1] if len(sys.argv) > 1 else ''
if STATUS not in ('idle', 'busy', 'waiting'):
    print('用法: esp32-led idle|busy|waiting')
    sys.exit(1)

# ── 方式 1：USB 串口 ──
_ports = glob.glob('/dev/cu.usbmodem*')
if _ports:
    try:
        fd = os.open(_ports[0], os.O_WRONLY | os.O_NOCTTY)
        os.write(fd, f'STATUS:{STATUS}\n'.encode())
        os.close(fd)
        sys.exit(0)
    except Exception:
        pass  # USB 失败，fallthrough 到 HTTP

# ── 方式 2：HTTP（WiFi） ──
_ip_file = os.path.expanduser('~/.esp32-led-ip')
if os.path.exists(_ip_file):
    with open(_ip_file) as f:
        ip = f.read().strip()
    try:
        url = f'http://{ip}/{STATUS}'
        urllib.request.urlopen(url, timeout=2)
        sys.exit(0)
    except Exception:
        pass

# ── 都失败 ──
sys.stderr.write(f'esp32-led: USB and HTTP both failed\n')
sys.exit(1)
